{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "Run Prettier",
         "type": "shell",
         "command": "npx",
         "args": [
            "prettier",
            "--write",
            "."
         ],
         "group": "build"
      },
      {
         "label": "Run ESLint",
         "type": "shell",
         "command": "npx",
         "args": [
            "eslint",
            "."
         ],
         "group": "build"
      }
   ]
}